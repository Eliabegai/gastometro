# ──────────────────────────────────────────────────────────────────
# gastometro — variáveis de ambiente para Docker Compose
#
# Copie este arquivo pra `.env` e ajuste os valores. O `.env` é
# carregado automaticamente pelo `docker compose` (não precisa
# `--env-file`) e fica fora do git (veja `.gitignore`).
# ──────────────────────────────────────────────────────────────────

# UID/GID do dono dos bind mounts (./dados, ./entrada, ./saida).
# No Mac, rode `id -u` e `id -g` pra pegar os seus.
APP_UID=1000
APP_GID=1000

# URL pública da planilha Google Sheets (família). Opcional — pode
# colar direto na UI. Quando setado, vira default da página Importar.
GASTOMETRO_PLANILHA_URL=

# ──────────────────────────────────────────────────────────────────
# ngrok — só relevante se você subir com `--profile ngrok`.
# ──────────────────────────────────────────────────────────────────

# Token da sua conta ngrok. Pegue em:
#   https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Domínio estático reservado no ngrok (plano Free dá 1 grátis em
# https://dashboard.ngrok.com/domains). Deixe vazio pra usar URL
# aleatória — útil pra testar antes de reservar.
NGROK_DOMAIN=

# Streamlit precisa relaxar XSRF/CORS pra funcionar atrás de proxy
# (ngrok, Cloudflare Tunnel, Tailscale Funnel). Sem isso o
# `st.file_uploader` quebra com erro de Axios e o websocket
# reconecta em loop.
# Mantenha `true` no uso local; ative `false` ao usar ngrok.
STREAMLIT_ENABLE_XSRF=true
STREAMLIT_ENABLE_CORS=true
